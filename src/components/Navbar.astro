---
import Logo from './Logo.astro';
const calendarPageUrl = '#';
export const LHD_BIRTHDAY = { month: 0, day: 9 };
export const BIRTHDAY_CELEBRATION_DURATION = 5000;
export const BIRTHDAY_CELEBRATION_DEBOUNCE = 2000;
export function isBirthday(date = new Date()): boolean {
	return date.getMonth() === LHD_BIRTHDAY.month && date.getDate() === LHD_BIRTHDAY.day;
}
---
<!-- things to add here in the future: link to all contributors, our main LHD website, etc -->
<header
  class="flex items-center gap-5 overflow-x-auto overflow-y-hidden border-b border-ut-offwhite px-7 py-4 md:overflow-x-hidden"
>
  <a
    href="https://chromewebstore.google.com/detail/ut-registration-plus/hboadpjkoaieogjimneceaahlppnipaa?utm_source=item-share-cb"
    title="Link to the Chrome Webstore Page"
    class="no-underline hover:no-underline"
  >
    <Logo size="large" />
  </a>

  <div
    class="mx-2 self-center md:mx-4"
    style="width:2px;height:2.5rem;background:var(--un-color-ut-offwhite,#D6D2C4)"
  >
  </div>

  <div class="flex flex-1 items-center gap-2">
    <h1 class="text-ut-burntorange normal-case text-xl font-semibold">
      Bye Bye !
    </h1>
    {
      isBirthday() && (
        <button
          type="button"
          class="bg-transparent px-4 text-sm text-ut-burntorange transition-transform hover:scale-110"
          title="Click to celebrate!"
        >
          🎉 Happy Birthday 🎉
        </button>
      )
    }
  </div>

  <div
    class="hidden flex-row items-center justify-end gap-7 screenshot:hidden lg:flex"
  >
    <a
      href="https://discord.gg/7pQDBGdmb7"
      title="Discord"
      class="text-ut-black hover:text-ut-burntorange transition-colors focusable"
    >
      <span class="sr-only">Discord</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0"></path>
        <path d="M14 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0"></path>
        <path d="M15.5 17c0 1 1.5 3 2 3c1.5 0 2.833 -1.671 3.5 -3c.667 -1.667 .5 -5.833 -1.5 -11.5c-1.457 -1.015 -3 -1.34 -4.5 -1.5l-.972 1.923a11.913 11.913 0 0 0 -4.053 0l-.975 -1.923c-1.5 .16 -3.043 .485 -4.5 1.5c-2 5.667 -2.167 9.833 -1.5 11.5c.667 1.329 2 3 3.5 3c.5 0 2 -2 2 -3"></path>
        <path d="M7 16.5c3.5 2 6.5 2 10 0"></path>
      </svg>
    </a>
    <a
      href="https://www.instagram.com/longhorndevelopers"
      title="Instagram"
      class="text-ut-black hover:text-ut-burntorange transition-colors focusable"
    >
      <span class="sr-only">Instagram</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
      </svg>
    </a>
    <a
      href="https://www.linkedin.com/company/longhorn-developers/posts/?feedView=all"
      title="LinkedIn"
      class="text-ut-black hover:text-ut-burntorange transition-colors focusable"
    >
      <span class="sr-only">LinkedIn</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
        <rect width="4" height="12" x="2" y="9"></rect>
        <circle cx="4" cy="4" r="2"></circle>
      </svg>
    </a>
    <a
      href="https://github.com/Longhorn-Developers"
      title="GitHub"
      class="mr-4 text-ut-black hover:text-ut-burntorange transition-colors focusable"
    >
      <!-- maybe there's a better way to do this but i only need this icon lol -->
      <span class="sr-only">GitHub</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
        ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
      >
    </a>
  </div>
</header>
